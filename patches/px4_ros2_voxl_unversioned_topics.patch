+/**
+ * @brief Checks whether PX4 topic-version suffixes should be suppressed.
+ *
+ * This workspace targets VOXL's unversioned PX4 ROS 2 topic graph by default, even when the
+ * local px4_msgs definitions contain MESSAGE_VERSION constants. Set
+ * PX4_ROS2_ENABLE_TOPIC_VERSION=1 only when running against a bridge that publishes versioned
+ * names such as fmu/out/vehicle_status_v4.
+ */
+static inline bool enableTopicVersion()
+{
+  const char* value = std::getenv("PX4_ROS2_ENABLE_TOPIC_VERSION");
+  return value != nullptr && std::string(value) == "1";
+}
